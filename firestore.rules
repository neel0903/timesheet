rules_version = '2';

// ════════════════════════════════════════════════════════════════════════════
//  Firestore Security Rules for Work Tracker
//  -----------------------------------------------------------------------
//  Paste this into:
//    Firebase Console → Firestore Database → Rules → (replace all) → Publish
//
//  WHAT THIS DOES
//  --------------
//  • Locks every user's data inside /users/{their-uid}/... so no other
//    authenticated user can read or write it.
//  • Validates payload shapes server-side (defense in depth — the client
//    can lie, but Firestore won't accept malformed writes).
//  • Hard-caps numeric values (hours, amounts) to defeat junk/abuse writes.
//  • Disables registration entirely:
//        - The client UI no longer offers "Create account".
//        - In Firebase Console → Authentication → Sign-in method →
//          Email/Password → DISABLE "User signup".
//          (Existing accounts can still sign in.)
//        - To create a new account in future, re-enable it temporarily,
//          register, then disable it again.
// ════════════════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // -------- helpers --------
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }
    function num(field, min, max) {
      return field is number && field >= min && field <= max;
    }
    function str(field, maxLen) {
      return field is string && field.size() <= maxLen;
    }
    function dateStr(field) {
      // YYYY-MM-DD format check
      return field is string && field.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$');
    }

    // -------- per-user namespace --------
    match /users/{uid} {
      // Allow accessing the user document itself only by its owner
      allow read, write: if isOwner(uid);

      // ---- Timesheet entries ----
      match /timesheet/{docId} {
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid)
          && dateStr(request.resource.data.date)
          && num(request.resource.data.reg, 0, 168)
          && num(request.resource.data.ot,  0, 60)
          && str(request.resource.data.notes, 500)
          && (
               !('auto' in request.resource.data) ||
               request.resource.data.auto is bool
             );
        allow delete: if isOwner(uid);
      }

      // ---- Expenses ----
      match /expenses/{docId} {
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid)
          && dateStr(request.resource.data.date)
          && str(request.resource.data.cat, 60)
          && num(request.resource.data.amt, 0, 1000000)
          && str(request.resource.data.desc, 500)
          && str(request.resource.data.ref,  200)
          && (
               !('subId' in request.resource.data) ||
               str(request.resource.data.subId, 100)
             );
        allow delete: if isOwner(uid);
      }

      // ---- Subscriptions ----
      match /subscriptions/{docId} {
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid)
          && str(request.resource.data.name, 200)
          && str(request.resource.data.cat,  60)
          && num(request.resource.data.amt,  0, 1000000)
          && num(request.resource.data.day,  1, 31)
          && dateStr(request.resource.data.start)
          && (request.resource.data.end == null || dateStr(request.resource.data.end))
          && str(request.resource.data.notes, 500)
          && request.resource.data.active is bool;
        allow delete: if isOwner(uid);
      }

      // ---- Payslips ----
      match /payslips/{docId} {
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid)
          && dateStr(request.resource.data.from)
          && dateStr(request.resource.data.to)
          && num(request.resource.data.hours, 0, 10000)
          && num(request.resource.data.rate,  0, 10000)
          && num(request.resource.data.amt,   0, 10000000)
          && str(request.resource.data.ref,   200)
          && str(request.resource.data.notes, 500);
        allow delete: if isOwner(uid);
      }

      // ---- Categories ----
      match /categories/{docId} {
        allow read: if isOwner(uid);
        allow create, update: if isOwner(uid)
          && str(request.resource.data.name,  60)
          && str(request.resource.data.icon,  10)
          && str(request.resource.data.color, 20);
        allow delete: if isOwner(uid);
      }
    }

    // Fallback: deny everything else explicitly.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
